{
  "name": "copilot-aiu",
  "version": "0.0.9",
  "description": "Analyze local GitHub Copilot CLI session usage, AI credits, token details, and mixed-model breakdowns.",
  "type": "module",
  "bin": {
    "copilot-aiu": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "watch": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github-copilot",
    "copilot-cli",
    "ai-credits",
    "cli",
    "usage"
  ],
  "author": "Çağatay Dilsiz",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "ink": "^7.0.5",
    "react": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
